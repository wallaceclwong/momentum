# Environment for sector-rotation.service
# Copy to /root/momentum/.env.sector and edit values.

# Repo + venv paths (absolute)
MOMENTUM_DIR=/root/momentum
MOMENTUM_VENV=/root/momentum/.venv

# Portfolio NAV in USD (bucket 2 target capital)
# Update whenever you add/withdraw capital
SECTOR_NAV=330000

# Execution mode:
#   simulate — simulate fills, write to DB only (NO IBKR connection)
#   ibkr     — connect to IB Gateway, place real orders
#   dry_run  — plan only, don't even write to DB
SECTOR_MODE=simulate

# NOTE: The main .env (for IBKR gateway credentials) must also be present at
# /root/momentum/.env with IBKR_HOST, IBKR_PORT (4001=paper, 4002=live),
# IBKR_CLIENT_ID, IBKR_LIVE=true. Port determines paper vs live account.
