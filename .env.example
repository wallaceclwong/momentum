# ── Telegram ──────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Trading mode ───────────────────────────────────────────────
TRADING_MODE=paper          # paper | live (for paper_trading.py)
PAPER_CAPITAL=100000

# ── Interactive Brokers ────────────────────────────────────────
# Fill these in when you have IBKR credentials.
# Run ibkr_setup_vm.sh on the VM first.

IBKR_HOST=127.0.0.1
IBKR_PORT=4001              # 4001 = paper gateway, 4002 = live gateway
IBKR_CLIENT_ID=1
IBKR_ACCOUNT_ID=            # e.g. U1234567 (paper) or DU1234567 (paper demo)
IBKR_LIVE=false             # set to true only when ready for live trading

# ── E*Trade (legacy — kept for reference) ─────────────────────
# ETRADE_CONSUMER_KEY=
# ETRADE_CONSUMER_SECRET=
# ETRADE_SANDBOX=true
